# wolfBoot configuration for AMD Versal VMK180 Evaluation Board
# Versal Prime VM1802 ACAP - Dual ARM Cortex-A72

ARCH?=AARCH64
TARGET?=versal

WOLFBOOT_VERSION?=1

# ECC-384 with SHA-384 (good balance of security and performance)
SIGN?=ECC384
HASH?=SHA384
IMAGE_HEADER_SIZE?=512

# RSA 4096-bit with SHA3-384 (alternative)
#SIGN?=RSA4096
#HASH?=SHA3
#IMAGE_HEADER_SIZE?=1024

# Debug options
DEBUG?=1
DEBUG_SYMBOLS=1
DEBUG_UART=1
CFLAGS_EXTRA+=-DDEBUG_VERSAL=1

VTOR?=1
CORTEX_M0?=0
NO_ASM?=0
ALLOW_DOWNGRADE?=0
NVM_FLASH_WRITEONCE?=0
V?=0
SPMATH?=1
RAM_CODE?=0
DUALBANK_SWAP?=0
PKA?=0
WOLFTPM?=0

# Flash configuration (stubs for now)
EXT_FLASH?=0
SPI_FLASH?=0
NO_XIP=1

# ELF loading support
ELF?=1
#DEBUG_ELF?=1

# Toolchain
USE_GCC=1
CROSS_COMPILE=aarch64-none-elf-
#CROSS_COMPILE=aarch64-linux-gnu-

# Memory Layout for Versal
# DDR starts at 0x0, wolfBoot loaded by PLM to DDR
WOLFBOOT_ORIGIN=0x00100000

# Flash Sector Size (placeholder - will depend on OSPI/QSPI flash)
WOLFBOOT_SECTOR_SIZE=0x10000

# Application Partition Size (64MB)
WOLFBOOT_PARTITION_SIZE=0x4000000

# Location in Flash for Primary Boot Partition (placeholder)
WOLFBOOT_PARTITION_BOOT_ADDRESS=0x00800000

# Load Partition to RAM Address
WOLFBOOT_LOAD_ADDRESS=0x10000000

# Location in Flash for Secondary Partition (placeholder)
WOLFBOOT_PARTITION_UPDATE_ADDRESS=0x04800000

# Location to store wolfBoot state (placeholder)
WOLFBOOT_PARTITION_SWAP_ADDRESS=0x08800000

# DTS (Device Tree) - optional
WOLFBOOT_LOAD_DTS_ADDRESS?=0x11800000
WOLFBOOT_DTS_BOOT_ADDRESS?=0x007C0000
WOLFBOOT_DTS_UPDATE_ADDRESS?=0x047C0000

# Speed up reads by using larger blocks
CFLAGS_EXTRA+=-DWOLFBOOT_SHA_BLOCK_SIZE=4096

# UART Configuration
# Versal UART0 is typically used for APU console
CFLAGS_EXTRA+=-DDEBUG_UART_NUM=0

